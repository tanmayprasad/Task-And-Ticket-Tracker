<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Backgrounds -->
    <SolidColorBrush x:Key="WindowBackground" Color="#0F111A"/>
    <SolidColorBrush x:Key="PanelBackground" Color="#161925"/>
    <SolidColorBrush x:Key="ControlBackground" Color="#1E2233"/>
    <SolidColorBrush x:Key="ControlHover" Color="#2A2F45"/>
    <SolidColorBrush x:Key="ControlSelected" Color="#323852"/>
    
    <!-- Accents -->
    <SolidColorBrush x:Key="PrimaryBackground" Color="#6366F1"/>
    <SolidColorBrush x:Key="PrimaryHover" Color="#4F46E5"/>
    <SolidColorBrush x:Key="SuccessColor" Color="#10B981"/>
    <SolidColorBrush x:Key="WarningColor" Color="#F59E0B"/>
    
    <!-- Borders -->
    <SolidColorBrush x:Key="BorderBrush" Color="#334155"/>
    <SolidColorBrush x:Key="BorderLight" Color="#1E293B"/>
    <SolidColorBrush x:Key="BorderMedium" Color="#475569"/>
    
    <!-- Typography -->
    <SolidColorBrush x:Key="TextPrimary" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#94A3B8"/>
    <SolidColorBrush x:Key="TextMuted" Color="#64748B"/>
    <SolidColorBrush x:Key="TextHighlight" Color="#CBD5E1"/>
    <SolidColorBrush x:Key="TextDark" Color="#475569"/>
    
    <!-- Overlay -->
    <SolidColorBrush x:Key="OverlayBackground" Color="#B30F111A"/>

    <!-- Geometry -->
    <CornerRadius x:Key="ControlCornerRadius">6</CornerRadius>
    <CornerRadius x:Key="CardCornerRadius">12</CornerRadius>
</ResourceDictionary>
