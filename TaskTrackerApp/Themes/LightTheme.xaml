<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Backgrounds -->
    <SolidColorBrush x:Key="WindowBackground" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="PanelBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ControlBackground" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="ControlHover" Color="#E2E8F0"/>
    <SolidColorBrush x:Key="ControlSelected" Color="#CBD5E1"/>
    
    <!-- Accents -->
    <SolidColorBrush x:Key="PrimaryBackground" Color="#6366F1"/>
    <SolidColorBrush x:Key="PrimaryHover" Color="#4F46E5"/>
    <SolidColorBrush x:Key="SuccessColor" Color="#10B981"/>
    <SolidColorBrush x:Key="WarningColor" Color="#F59E0B"/>
    
    <!-- Borders -->
    <SolidColorBrush x:Key="BorderBrush" Color="#E2E8F0"/>
    <SolidColorBrush x:Key="BorderLight" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="BorderMedium" Color="#CBD5E1"/>
    
    <!-- Typography -->
    <SolidColorBrush x:Key="TextPrimary" Color="#0F172A"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#334155"/>
    <SolidColorBrush x:Key="TextMuted" Color="#64748B"/>
    <SolidColorBrush x:Key="TextHighlight" Color="#475569"/>
    <SolidColorBrush x:Key="TextDark" Color="#94A3B8"/>
    
    <!-- Overlay -->
    <SolidColorBrush x:Key="OverlayBackground" Color="#4C0F172A"/>

    <!-- Geometry -->
    <CornerRadius x:Key="ControlCornerRadius">6</CornerRadius>
    <CornerRadius x:Key="CardCornerRadius">12</CornerRadius>
</ResourceDictionary>
